{
  "name": "@cori.agent/dataverse",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "author": "Rural Innovation Strategies, Inc.",
  "description": "A universe of rural innovation data, tools, research, and analysis from the Center on Rural Innovation (CORI)",
  "license": "ISC",
  "homepage": "https://ruralinnovation.github.io/blog/",
  "keywords": [
    "blog",
    "documentation",
